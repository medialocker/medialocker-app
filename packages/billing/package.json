{
  "name": "@medialocker/billing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "echo 'lint ok'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "setup:stripe": "tsx scripts/setup-stripe.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@medialocker/auth": "workspace:*",
    "@medialocker/config": "workspace:*",
    "@medialocker/core": "workspace:*",
    "@medialocker/observability": "workspace:*",
    "postgres": "^3.4.5",
    "stripe": "^17.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
