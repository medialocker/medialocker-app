# Core
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_BASE_DOMAIN=<your-domain>
S3_PUBLIC_ENDPOINT=https://s3.<your-domain>
OTEL_EXPORTER_OTLP_ENDPOINT=

# Postgres + Auth — Supabase Cloud (managed). Create a project at supabase.com and
# copy the values from Project Settings → Database (connection strings) and
# Settings → API (keys + JWT secret).
#
# App runtime (api/worker/mcp) uses the TRANSACTION pooler (port 6543); prepared
# statements are disabled in code for it. Keep `?sslmode=require`.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# Migrations + setup-stripe need a SESSION-persistent connection (they hold a
# session-level advisory lock) — run them against the SESSION pooler (5432) or the
# direct connection, e.g.:
#   DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require \
#     pnpm --filter @medialocker/db migrate
SUPABASE_URL=https://<project-ref>.supabase.co
# Secret API key (Project Settings → API Keys → Secret). Backend/admin-tooling only
# (e.g. the dev seed's Admin API) — never expose to the browser. Replaces the legacy
# service_role key. Dashboard session JWTs need NO shared secret: they are verified
# against the project JWKS (asymmetric ES256) using SUPABASE_URL above.
SUPABASE_SECRET_KEY=sb_secret_...

# Redis
REDIS_URL=redis://localhost:6379
# Required by docker-compose (the redis container runs with --requirepass).
REDIS_PASSWORD=<generate>

# Hetzner Object Storage (S3-compatible)
# Endpoint is region-specific, e.g. fsn1 (Falkenstein), nbg1 (Nuremberg),
# hel1 (Helsinki): https://<region>.your-objectstorage.com
HETZNER_S3_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_S3_REGION=fsn1
# Generate an access key/secret pair in the Hetzner Cloud Console
# (project → Security → S3 credentials).
HETZNER_S3_ACCESS_KEY=<generate>
HETZNER_S3_SECRET_KEY=<generate>

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIG_ID=

# Transactional email (Resend) — backend only, never exposed to the browser.
# Leave RESEND_API_KEY blank to disable email (it becomes a logged no-op, like an
# unset STRIPE_SECRET_KEY). EMAIL_FROM must use a Resend-verified domain; for
# quick testing without DNS setup use the sandbox: EMAIL_FROM=onboarding@resend.dev
# CONTACT_INBOX receives website contact-form submissions.
RESEND_API_KEY=
EMAIL_FROM=MediaLocker <no-reply@medialocker.io>
CONTACT_INBOX=support@medialocker.io
EMAIL_LOGO_URL=https://medialocker.io/email-logo.png

# Internal service-to-service auth
INTERNAL_API_SECRET=<generate>
# Worker metrics/dashboard (internal network only, never publicly routed — P3.11).
# Optional bearer token for /metrics and /admin/queues; leave blank to rely on
# internal-network isolation alone. Generate with: openssl rand -hex 32
WORKER_METRICS_TOKEN=
# Must be a base64-encoded 32-byte key. Generate with: openssl rand -base64 32
API_KEY_ENC_KEY=<generate>

# Wildcard TLS (Caddy DNS-01)
CLOUDFLARE_API_TOKEN=

# Analytics
PLAUSIBLE_DOMAIN=
PLAUSIBLE_SECRET_KEY=

# ClickHouse
CLICKHOUSE_PASSWORD=
