# Dashboard (apps/app) — browser-exposed config.
# Every NEXT_PUBLIC_* value is inlined into the client bundle, so only put
# publishable values here (never the service-role key or any secret).

# Control-plane API base the dashboard calls (presign, media, billing, …).
NEXT_PUBLIC_API_URL=https://api.medialocker.io

# Supabase Cloud project URL + publishable anon key (browser auth only).
# From Project Settings → API Keys. Inlined at build time — both MUST be set when
# building for any real environment. The publishable key (sb_publishable_…) is the
# current client-side key, replacing the legacy anon key.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Parent domain the middleware uses to build the CSP host allowlist (S3, API,
# Supabase). Defaults to medialocker.io when unset.
NEXT_PUBLIC_BASE_DOMAIN=medialocker.io

# Parent cookie domain for the @supabase/ssr session cookies. Leave UNSET in
# local dev so cookies stay per-origin. Set to a leading-dot parent (e.g.
# `.medialocker.io`) to SHARE the auth session across subdomains of the parent
# domain. Cookies remain Secure + httpOnly + SameSite=Lax.
# NEXT_PUBLIC_COOKIE_DOMAIN=.medialocker.io
