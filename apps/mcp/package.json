    "@modelcontextprotocol/sdk": "^1.29.0",
    "bullmq": "^5.0.0",
    "@reaatech/mcp-gateway-allowlist": "^1.1.0",
    "@reaatech/mcp-gateway-audit": "^1.1.0",
